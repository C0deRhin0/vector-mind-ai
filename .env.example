# ─── LLM Provider (choose ONE) ───────────────────────────
LLM_PROVIDER=ollama          # Options: ollama, openai, anthropic, google

# Ollama (local, default)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google
# GOOGLE_API_KEY=...
# GOOGLE_MODEL=gemini-2.5-flash

# ─── Vector Database ─────────────────────────────────────
QDRANT_URL=http://localhost:6333
COLLECTION_NAME=research_docs

# ─── Embeddings ──────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
VECTOR_SIZE=384

# ─── Web Search (optional) ──────────────────────────────
# Exa API key for web search capability
# EXA_API_KEY=...
# Firecrawl API key for deep crawling
# FIRECRAWL_API_KEY=...

# ─── Research Config ────────────────────────────────────
MAX_RESEARCH_DEPTH=3        # Max agent recursion depth
TOP_K=10                    # Chunks to retrieve per search
SCORE_THRESHOLD=0.2         # Minimum relevance score
